        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "EXPO_PUBLIC_SUPABASE_URL": "https://ibfcfqleupjyjemuvcia.supabase.co",
      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImliZmNmcWxldXBqeWplbXV2Y2lhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUyMTU3NDksImV4cCI6MjA5MDc5MTc0OX0.fg3EHlkR8u5nfTTv2-Oj2B1eKMYOLFxGsr60N00NsYQ"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
